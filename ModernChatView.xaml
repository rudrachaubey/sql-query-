<views:BaseView x:Class="Bhive.Views.Modern.ModernChatView"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:views="clr-namespace:Bhive.Views"
                xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                xmlns:bhivecontrols="clr-namespace:Bhive.Wpf.Controls"
                xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
                xmlns:converters="clr-namespace:Bhive.Wpf.Converters"
                xmlns:comms="clr-namespace:Bhive.Communication;assembly=Bhive.Communication"
                mc:Ignorable="d"
                DataContext="{Binding ModernDrawerChatViewModel, Source={StaticResource Locator}}">

    <views:BaseView.Resources>
        <converters:PresenceConverter x:Key="PresenceConverter" />
        <converters:NonCachedImageConverter x:Key="NonCachedImageConverter" />
        <converters:CollapsedBoolVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseCollapsedConverter x:Key="InvBoolToVis" />
        <converters:NotEmptyVisibilityConverter x:Key="NotEmptyToVis" />


        <DataTemplate x:Key="ChatItemTemplate">
            <Border x:Name="ItemBorder"
                    CornerRadius="8"
                    Margin="0,0,0,8"
                    Cursor="Hand"
                    SnapsToDevicePixels="True"
                    Padding="12,8">
              
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Style.Triggers>
                            <!-- Hover state (only if not selected) -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                                               Value="True" />
                                    <Condition Binding="{Binding IsSelected}"
                                               Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background"
                                        Value="{DynamicResource OnPageBrush}" />
                                <!-- Subtle white overlay -->
                            </MultiDataTrigger>

                            <!-- Selected state -->
                            <DataTrigger Binding="{Binding IsSelected}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#2D2D2D" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Background="Transparent">
                    <Grid.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.SelectChatCommand, RelativeSource={RelativeSource AncestorType=views:BaseView}}"
                                      CommandParameter="{Binding}" />
                    </Grid.InputBindings>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Avatar / Initials -->
                    <Grid Width="36"
                          Height="36"
                          Margin="0,0,10,0"
                          VerticalAlignment="Center">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#444" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowPresence}" Value="True">
                                            <Setter Property="Fill" Value="{Binding CurrentPresence, Converter={StaticResource PresenceConverter}}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ChatInitials, FallbackValue='XX'}"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   >
                        <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowProfilePicture}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- ProfilePicture Ellipse -->
                        <Ellipse StrokeThickness="2"
                                 Stroke="{Binding CurrentPresence, Converter={StaticResource PresenceConverter}, FallbackValue='#444'}">
                            <Ellipse.Fill>
                                <ImageBrush Stretch="UniformToFill" ImageSource="{Binding ProfilePicture, Converter={StaticResource NonCachedImageConverter}}" />
                            </Ellipse.Fill>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowProfilePicture}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="1">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="2">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Break Background Ellipse -->
                        <Ellipse StrokeThickness="0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="1">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Fill" Value="#FF4C4C"/>
                                            <Setter Property="Stroke" Value="#FF4C4C"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="2">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Fill" Value="#FF4C4C"/>
                                            <Setter Property="Stroke" Value="#FF4C4C"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Break Image Overlay Ellipse -->
                        <Ellipse StrokeThickness="2"
                                 Stroke="Transparent">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="1">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Fill">
                                                <Setter.Value>
                                                    <ImageBrush Stretch="UniformToFill" ImageSource="{StaticResource BhiveTeaBreak}"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="2">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Fill">
                                                <Setter.Value>
                                                    <ImageBrush Stretch="UniformToFill" ImageSource="{StaticResource BhiveLunchBreak}"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding ChatDescription, FallbackValue='User Name'}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextActionBrush}" />
                        <TextBlock Text="{Binding ChatDescriptionSubtext}"
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextActionBrush}"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ChatDescriptionSubtext}"
                                                     Value="{x:Null}">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ChatDescriptionSubtext}"
                                                     Value="">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Notification Dot -->
                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Margin="0,0,4,0">
                        <bhivecontrols:NotificationDot HorizontalAlignment="Right"
                                          Visibility="{Binding HasUnreadMessages, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Pin/Unpin Button (shows on hover) -->
                    <Button Grid.Column="3"
        Width="20"
        Height="20"
        Command="{Binding DataContext.PinChatCommand, RelativeSource={RelativeSource AncestorType=views:BaseView}}"
        CommandParameter="{Binding}">

                        <svg:SvgViewbox Source="pack://application:,,,/Bhive;component/Images/Modern/Pin-Outline.svg"
                    Width="12"
                    Height="12"
                    Stretch="Uniform" />

                        <Button.Style>
                            <!-- 🔥 Merge with your hover style -->
                            <Style TargetType="Button" BasedOn="{StaticResource PinIconButtonStyle}">

                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsPinned}" Value="False"/>
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True"/>
                                        </MultiDataTrigger.Conditions>

                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Opacity" Value="1"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>

                            </Style>
                        </Button.Style>

                    </Button>

                    <!-- Unpin Button -->
                    <Button Grid.Column="3"
        Width="20"
        Height="20"
        Command="{Binding DataContext.UnpinChatCommand, RelativeSource={RelativeSource AncestorType=views:BaseView}}"
        CommandParameter="{Binding}">

                        <svg:SvgViewbox Source="pack://application:,,,/Bhive;component/Images/Modern/Pin-Filled.svg"
                    Width="12"
                    Height="12"
                    Stretch="Uniform" />

                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PinIconButtonStyle}">

                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsPinned}" Value="True"/>
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True"/>
                                        </MultiDataTrigger.Conditions>

                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Opacity" Value="1"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>

                            </Style>
                        </Button.Style>

                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template for Search Results -->
        <DataTemplate x:Key="SearchResultTemplate">
            <!-- Border for separator -->
            <Border BorderBrush="{DynamicResource BordersBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,10"
                    Margin="12,0">
                <Grid Background="Transparent"
                      Cursor="Hand">
                    <Grid.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.SelectChatCommand, RelativeSource={RelativeSource AncestorType=views:BaseView}}"
                                      CommandParameter="{Binding}" />
                    </Grid.InputBindings>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="36"
                          Height="36"
                          Margin="0,0,10,0">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#444" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowPresence}" Value="True">
                                            <Setter Property="Fill" Value="{Binding CurrentPresence, Converter={StaticResource PresenceConverter}}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding Initials}"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowProfilePicture}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- ProfilePicture Ellipse -->
                        <Ellipse StrokeThickness="2"
                                 Stroke="{Binding CurrentPresence, Converter={StaticResource PresenceConverter}, FallbackValue='#444'}">
                            <Ellipse.Fill>
                                <ImageBrush Stretch="UniformToFill" ImageSource="{Binding ProfilePicture, Converter={StaticResource NonCachedImageConverter}}" />
                            </Ellipse.Fill>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowProfilePicture}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="1">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="2">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Break Background Ellipse -->
                        <Ellipse StrokeThickness="0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="1">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Fill" Value="#FF4C4C"/>
                                            <Setter Property="Stroke" Value="#FF4C4C"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="2">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Fill" Value="#FF4C4C"/>
                                            <Setter Property="Stroke" Value="#FF4C4C"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Break Image Overlay Ellipse -->
                        <Ellipse StrokeThickness="2"
                                 Stroke="Transparent">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="1">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Fill">
                                                <Setter.Value>
                                                    <ImageBrush Stretch="UniformToFill" ImageSource="{StaticResource BhiveTeaBreak}"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentActivityId}" Value="2">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Fill">
                                                <Setter.Value>
                                                    <ImageBrush Stretch="UniformToFill" ImageSource="{StaticResource BhiveLunchBreak}"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>

                    <!-- Name only — no ConnectionType sub-label -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding Name}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextActionBrush}"
                               Background="Transparent"
                               Cursor="Hand" />
                </Grid>
            </Border>
        </DataTemplate>
    </views:BaseView.Resources>

    <Grid TextElement.FontFamily="{StaticResource InterFontFamily}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- COL 1: CHAT LIST (Transparent on Gradient) -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource BordersBrush}"
                BorderThickness="0">

            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Row 0: Header -->
                <Grid Height="40"
                      VerticalAlignment="Top"
                      Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Chat"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextActionBrush}"
                               VerticalAlignment="Center" />

                    <!-- New Chat Icon (Filled when active, Outline when inactive) -->
                    <Button Grid.Column="1"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Cursor="Hand"
                            Command="{Binding ToggleSearchCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="HoverBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Width="28"
                                                    Height="28">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter TargetName="HoverBorder"
                                                            Property="Background"
                                                            Value="{DynamicResource OnPageBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <Grid Width="20"
                              Height="20">
                            <!-- Filled: shown when search/new-chat panel is open -->
                            <svg:SvgViewbox Source="pack://application:,,,/Bhive;component/Images/Modern/New_chat-Filled.svg"
                                            Width="20"
                                            Height="20"
                                            Visibility="{Binding IsSearchOpen, Converter={StaticResource BoolToVis}}" />
                            <!-- Outline: shown when panel is closed -->
                            <svg:SvgViewbox Source="pack://application:,,,/Bhive;component/Images/Modern/New_chat-Outline.svg"
                                            Width="20"
                                            Height="20"
                                            Visibility="{Binding IsSearchOpen, Converter={StaticResource InvBoolToVis}}" />
                        </Grid>
                    </Button>
                </Grid>

                <!-- Row 1: Content (Chat Lists Only) -->
                <Grid Grid.Row="1">
                    <ScrollViewer x:Name="ChatListScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <StackPanel>
                            <!-- Quick Chat -->
                            <StackPanel Margin="0,0,0,24">
                                <TextBlock Text="QUICK CHAT"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource SecondaryTextActionBrush}"
                                           Margin="0,0,0,8" />

                                <UniformGrid Columns="3"
                                             HorizontalAlignment="Stretch">
                                    <Border Margin="0,0,8,0"
                                            CornerRadius="4"
                                            Background="{DynamicResource PageBrush}">

                                        <Button Content="Team"
                                                Style="{StaticResource ModernHoverButton}"
                                                controls:ControlsHelper.CornerRadius="4"
                                                Height="28"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Command="{Binding SelectQuickChatCommand}"
                                                CommandParameter="Team" />
                                    </Border>

                                    <Border Margin="0,0,8,0"
                                            CornerRadius="4"
                                            Background="{DynamicResource PageBrush}">
                                        <Button Content="Manager"
                                                Style="{StaticResource ModernHoverButton}"
                                                controls:ControlsHelper.CornerRadius="4"
                                                Height="28"
                                                Padding="auto"
                                                Foreground="White"
                                                BorderThickness="0"
                                                IsEnabled="{Binding HasTeamSupervisor}"
                                                Command="{Binding SelectQuickChatCommand}"
                                                CommandParameter="Manager" />
                                    </Border>
                                    <Border Margin="0,0,8,0"
                                            CornerRadius="4"
                                            Background="{DynamicResource PageBrush}">
                                        <Button Content="HR"
                                                Style="{StaticResource ModernHoverButton}"
                                                controls:ControlsHelper.CornerRadius="4"
                                                Height="28"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Command="{Binding SelectQuickChatCommand}"
                                                CommandParameter="HR" />
                                    </Border>
                                </UniformGrid>
                            </StackPanel>

                            <!-- My Team -->
                            <StackPanel Margin="0,0,0,24">
                                <Grid Margin="0,0,6,8"
                                      Background="Transparent"
                                      Cursor="Hand">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding ToggleTeamChatsCommand}" />
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="MY TEAM"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource SecondaryTextActionBrush}" />
                                    <!-- Chevron -->
                                    <Grid Grid.Column="1"
                                          Width="16"
                                          Height="16"
                                          Background="Transparent"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path Data="M0,0 L4,4 L0,8"
                                              Stroke="{DynamicResource SecondaryTextActionBrush}"
                                              StrokeThickness="1.5"
                                              Stretch="None"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RenderTransformOrigin="0.5,0.5">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTeamChatsExpanded}"
                                                                     Value="False">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="0" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                </Grid>

                                <Grid Visibility="{Binding IsTeamChatsExpanded, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl ItemsSource="{Binding UserChats.TeamChats}"
                                                  ItemTemplate="{StaticResource ChatItemTemplate}" />
                                    <TextBlock Text="No team chats yet"
                                               FontSize="12"
                                               Foreground="#66FFFFFF"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UserChats.TeamChats.Count}"
                                                                 Value="0">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                            <!-- Favorites -->
                            <StackPanel Margin="0,0,0,24">
                                <Grid Margin="0,0,6,8"
                                      Background="Transparent"
                                      Cursor="Hand">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding ToggleFavoritesCommand}" />
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FAVORITES"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource SecondaryTextActionBrush}" />
                                    <!-- Chevron -->
                                    <Grid Grid.Column="1"
                                          Width="16"
                                          Height="16"
                                          Background="Transparent"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path Data="M0,0 L4,4 L0,8"
                                              Stroke="{DynamicResource SecondaryTextActionBrush}"
                                              StrokeThickness="1.5"
                                              Stretch="None"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RenderTransformOrigin="0.5,0.5">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFavoritesExpanded}"
                                                                     Value="False">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="0" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                </Grid>

                                <Grid Visibility="{Binding IsFavoritesExpanded, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl ItemsSource="{Binding UserChats.PinnedChats}"
                                                  ItemTemplate="{StaticResource ChatItemTemplate}" />
                                    <TextBlock Text="Your favourites will appear here"
                                               FontSize="12"
                                               Foreground="#66FFFFFF"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UserChats.PinnedChats.Count}"
                                                                 Value="0">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                            <!-- Recent Chats / Direct Messages -->
                            <StackPanel Margin="0,0,0,24">
                                <Grid Margin="0,0,6,8"
                                      Background="Transparent"
                                      Cursor="Hand">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding ToggleRecentChatsCommand}" />
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="RECENT CHATS"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource SecondaryTextActionBrush}" />
                                    <!-- Chevron -->
                                    <Grid Grid.Column="1"
                                          Width="16"
                                          Height="16"
                                          Background="Transparent"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path Data="M0,0 L4,4 L0,8"
                                              Stroke="{DynamicResource SecondaryTextActionBrush}"
                                              StrokeThickness="1.5"
                                              Stretch="None"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RenderTransformOrigin="0.5,0.5">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRecentChatsExpanded}"
                                                                     Value="False">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="0" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                </Grid>

                                <Grid Visibility="{Binding IsRecentChatsExpanded, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl ItemsSource="{Binding UserChats.RecentChats}"
                                                  ItemTemplate="{StaticResource ChatItemTemplate}" />
                                    <TextBlock Text="No recent chats yet"
                                               FontSize="12"
                                               Foreground="#66FFFFFF"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UserChats.RecentChats.Count}"
                                                                 Value="0">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- Click-Outside Overlay for Chat List -->
        <Grid Grid.Column="0"
              Background="Transparent"
              Visibility="{Binding IsSearchOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding CloseSearchCommand}" />
            </Grid.InputBindings>
        </Grid>

        <!-- COL 2: MAIN CHAT AREA (Dark Card) -->
        <Border Grid.Column="1"
                Background="{DynamicResource PageBrush}"
                CornerRadius="10,0,0,0">
            <Grid>
                <!-- Soft depth gradient inner overlay -->
                <Grid Background="{DynamicResource SurfaceBgGradientBrush}"
                      Opacity="0.18" />

                <!-- Chat Interface -->
                <Grid Visibility="{Binding IsChatOpen, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!-- Title Bar -->
                        <RowDefinition Height="*" />
                        <!-- Chat Content -->
                    </Grid.RowDefinitions>

                    <!-- Chat Header -->
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource BordersBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="20,15">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <!-- Avatar -->
                                <Grid Width="34" Height="34" Margin="0,0,10,0" Cursor="Hand">
                                    <Grid.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.OpenProfileModalCommand, RelativeSource={RelativeSource AncestorType={x:Type views:BaseView}}}" />
                                    </Grid.InputBindings>
                                    
                                    <!-- Fallback Initials -->
                                    <Border CornerRadius="17">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource BordersBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RecentChat.ShowProfilePicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding RecentChat.ChatInitials}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextActionBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RecentChat.ShowProfilePicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Profile Picture Overlay -->
                                    <Ellipse Visibility="{Binding RecentChat.ShowProfilePicture, Converter={StaticResource BoolToVis}}">
                                        <Ellipse.Fill>
                                            <ImageBrush Stretch="UniformToFill" ImageSource="{Binding RecentChat.ProfilePicture, Converter={StaticResource NonCachedImageConverter}}" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>

                                <!-- Name -->
                                <TextBlock Text="{Binding ChatTitle}"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextActionBrush}"
                                           Cursor="Hand"
                                           Background="Transparent">
                                    <TextBlock.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.OpenProfileModalCommand, RelativeSource={RelativeSource AncestorType={x:Type views:BaseView}}}"
                                                      CommandParameter="{Binding DataContext.CurrentChatOtherUserId, RelativeSource={RelativeSource AncestorType={x:Type views:BaseView}}}"/>
                                    </TextBlock.InputBindings>
                                </TextBlock>
                            </StackPanel>

                            <!-- Window / Call Controls -->
                            <!-- 3-Dots Header Menu -->
                            <StackPanel HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <!-- The ... trigger button -->
                                <Button x:Name="HeaderMenuButton"
                                        Width="28"
                                        Height="28"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FocusVisualStyle="{x:Null}"
                                        Command="{Binding ToggleHeaderMenuCommand}"
                                        ToolTip="More options">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="6"
                                                                Width="28"
                                                                Height="28">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver"
                                                                     Value="True">
                                                                <Setter TargetName="Bg"
                                                                        Property="Background"
                                                                        Value="{DynamicResource OnPageBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <!-- Three dots -->
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <Ellipse Width="3"
                                                 Height="3"
                                                 Fill="{DynamicResource SecondaryTextActionBrush}"
                                                 Margin="1,0" />
                                        <Ellipse Width="3"
                                                 Height="3"
                                                 Fill="{DynamicResource SecondaryTextActionBrush}"
                                                 Margin="1,0" />
                                        <Ellipse Width="3"
                                                 Height="3"
                                                 Fill="{DynamicResource SecondaryTextActionBrush}"
                                                 Margin="1,0" />
                                    </StackPanel>
                                </Button>

                                <!-- Dropdown popup -->
                                <Popup IsOpen="{Binding IsHeaderMenuOpen, Mode=TwoWay}"
                                       PlacementTarget="{Binding ElementName=HeaderMenuButton}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       HorizontalOffset="-90"
                                       VerticalOffset="4">
                                    <Border Background="{DynamicResource OnPageBrush}"
                                            BorderBrush="{DynamicResource BordersBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            MinWidth="120"
                                            Padding="4">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12"
                                                              ShadowDepth="2"
                                                              Opacity="0.35"
                                                              Color="#000000" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <!-- Pin item -->
                                            <Button Command="{Binding PinCurrentChatCommand}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalContentAlignment="Left"
                                                    Cursor="Hand"
                                                    FocusVisualStyle="{x:Null}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="ItemBg"
                                                                            Background="Transparent"
                                                                            CornerRadius="5"
                                                                            Padding="10,8">
                                                                        <ContentPresenter />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver"
                                                                                 Value="True">
                                                                            <Setter TargetName="ItemBg"
                                                                                    Property="Background"
                                                                                    Value="{DynamicResource PageBrush}" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Pin icon path -->
                                                    <Path Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                                          Fill="{DynamicResource PrimaryTextActionBrush}"
                                                          Width="13"
                                                          Height="13"
                                                          Stretch="Uniform"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,0,0" />
                                                    <TextBlock Text="Pin"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource PrimaryTextActionBrush}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>

                        </Grid>
                    </Border>

                    <!-- Chat Control -->
                    <comms:CommunicationControl Grid.Row="1"
                                                x:Name="CommunicationControl"
                                                Visibility="{Binding HasChatFailedToInitialize, Converter={StaticResource InvBoolToVis}}"
                                                Opacity="1"
                                                Cursor="Hand"
                                                UseReactAssets="True"
                                                FocusVisualStyle="{x:Null}" />

                    <!-- Error State -->
                    <Grid Grid.Row="1"
                          Background="{DynamicResource PageBrush}"
                          Visibility="{Binding HasChatFailedToInitialize, Converter={StaticResource BoolToVis}}">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Oops, failed to load chat"
                                       Foreground="{DynamicResource PrimaryTextActionBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,20" />
                            <Button Content="Retry"
                                    Background="{DynamicResource PrimaryActionBrush}"
                                    Foreground="White"
                                    Width="100"
                                    Padding="20,8"
                                    BorderThickness="0"
                                    Visibility="{Binding IsChatRetryEnabled, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding RetryOpenChatCommand}" />
                        </StackPanel>
                    </Grid>

                </Grid>

                <!-- State 1: Default Empty State (Show when NO chat is open AND Search is closed) -->
                <Grid Visibility="{Binding IsChatOpen, Converter={StaticResource InvBoolToVis}}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchOpen}"
                                             Value="True">
                                    <Setter Property="Visibility"
                                            Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="{Binding IsSearchOpen, Converter={StaticResource InvBoolToVis}}">

                        <Image Source="/Images/Modern/ChatBubble.png"
                               Width="100"
                               Height="80"
                               Margin="0,0,0,20" />

                        <TextBlock Text="Welcome! 👋"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Foreground="White"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="Select a chat or start a new conversation to see messages here."
                                   FontSize="13"
                                   Foreground="{DynamicResource SecondaryTextActionBrush}"
                                   Width="300"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20" />

                        <Border Width="100"
                                CornerRadius="4"
                                Background="{DynamicResource PrimaryActionBrush}">

                            <Button Content="New chat"
                                    Style="{StaticResource ModernHoverButton}"
                                    controls:ControlsHelper.CornerRadius="4"
                                    Foreground="White"
                                    Padding="20,8"
                                    BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ToggleSearchCommand}" />
                        </Border>

                    </StackPanel>
                </Grid>

                <!-- State 2: Search / New Message State -->
                <Grid Visibility="{Binding IsSearchOpen, Converter={StaticResource BoolToVis}}"
                      Panel.ZIndex="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- "To: [Input]" Header -->
                    <Border x:Name="SearchHeader"
                            Background="{DynamicResource PageBrush}"
                            BorderBrush="{DynamicResource BordersBrush}"
                            BorderThickness="0"
                            Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- To Label -->
                            <TextBlock Text="To:"
                   FontSize="14"
                   Foreground="{DynamicResource SecondaryTextActionBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0" />

                            <!-- Input + Placeholder -->
                            <Grid Grid.Column="1">

                                <!-- TextBox -->
                                <TextBox x:Name="SearchBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         CaretBrush="White"
                                         Foreground="{DynamicResource PrimaryTextActionBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,2,0,0">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent" />
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>

                                <TextBlock Text="Enter name to continue"
           Foreground="{DynamicResource SecondaryTextActionBrush}"
           VerticalAlignment="Center"
           Margin="2,2,0,0"
           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>

                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0"/>
                                                        <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchBox}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>

                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </Grid>
                        </Grid>
                    </Border>


                    <!-- Search Results (Popup to overcome Airspace issue) -->
                    <Popup IsOpen="{Binding IsSearchOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=SearchHeader}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           HorizontalOffset="0"
                           VerticalOffset="0">
                        <!-- Floating Search Panel -->
                        <Grid Width="{Binding ActualWidth, ElementName=SearchHeader}">
                            <Border Width="800"
                                    Visibility="{Binding SearchText, Converter={StaticResource NotEmptyToVis}}"
                                    Margin="0,0,0,20"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource OnPageBrush}"
                                    BorderBrush="{DynamicResource BordersBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15"
                                                      ShadowDepth="2"
                                                      Opacity="0.3" />
                                </Border.Effect>

                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              MaxHeight="300">
                                    <StackPanel>
                                        <TextBlock Text="SUGGESTED"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource SecondaryTextActionBrush}"
                                                   Margin="20,16,20,8"
                                                   Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVis}}" />

                                        <ItemsControl ItemsSource="{Binding SearchResults}"
                                                      ItemTemplate="{StaticResource SearchResultTemplate}" />

                                        <TextBlock Text="No people found"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextActionBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,20"
                                                   Visibility="{Binding IsNoResultsFound, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Popup>

                    <!-- Transparent overlay to catch clicks outside while search is open -->
                    <Grid Grid.Row="1"
                          Background="Transparent"
                          Visibility="{Binding IsSearchOpen, Converter={StaticResource BoolToVis}}">
                        <Grid.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding CloseSearchCommand}" />
                        </Grid.InputBindings>
                    </Grid>
                </Grid>

            </Grid>
        </Border>

    </Grid>
</views:BaseView>
