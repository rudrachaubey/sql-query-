<views:BaseView x:Class="Bhive.Views.Modern.FullScreen"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:views="clr-namespace:Bhive.Views"
                xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                xmlns:bhivecontrols="clr-namespace:Bhive.Wpf.Controls"
                xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
                xmlns:converters="clr-namespace:Bhive.Wpf.Converters"
                xmlns:comms="clr-namespace:Bhive.Communication;assembly=Bhive.Communication"
                xmlns:local="clr-namespace:Bhive.Views.Modern"
                xmlns:enums="clr-namespace:Bhive.Enums"
                DataContext="{Binding FullScreenViewModel, Source={StaticResource Locator}}"
                mc:Ignorable="d"
                >

    <views:BaseView.Resources>
        <converters:CollapsedBoolVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseCollapsedConverter x:Key="InvBoolToVis"/>
		<converters:PresenceWithBreakConverter x:Key="PresenceWithBreakConverter"/>
        <converters:CharacterCountConverter x:Key="CharacterCountConverter"/>
        <converters:NonCachedImageConverter x:Key="NonCachedImageConverter"/>
        <Style x:Key="BhiveButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontFamily"                   Value="{DynamicResource InterFontFamily}"/>
            <Setter Property="FontSize"                     Value="12"/>
            <Setter Property="FontWeight"                   Value="Medium"/>
            <Setter Property="Cursor"                       Value="Hand"/>
            <Setter Property="HorizontalContentAlignment"   Value="Center"/>
            <Setter Property="VerticalContentAlignment"     Value="Center"/>
            <Setter Property="Padding"                      Value="2,2,2,2"/>
            <Setter Property="Background"                   Value="#3D3D3D"/>
            <Setter Property="Foreground"                   Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        Width="100"
                        Height="30"
                        Margin="0,0,0,0"
                        BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#52BCCC"/>
                            </Trigger>
                            <!-- Disabled (optional) -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True">
                    <Setter Property="BorderBrush" Value="#3D3D3D"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsPressed}" Value="True">
                    <Setter Property="BorderBrush" Value="#52BCCC"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Foreground" Value="#262626"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BhiveSaveButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontFamily"
                    Value="{DynamicResource InterFontFamily}" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="FontWeight"
                    Value="Medium" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="Padding"
                    Value="2,2,2,2" />
            <Setter Property="Background"
                    Value="#52BCCC" />
            <Setter Property="Foreground"
                    Value="#262626" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Width="70"
                                Height="30"
                                Margin="0,0,0,0"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="12,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="BorderBrush"
                                        Value="#3D3D3D" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#52BCCC" />
                            </Trigger>
                            
                            <!-- Disabled (optional) -->
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="bd"
                                        Property="Opacity"
                                        Value="1" />
                                <Setter Property="Background"
                                        Value="#3D3D3D" />
                                <Setter Property="Foreground"
                                        Value="#D1D1D1" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}"
                             Value="True">
                    <Setter Property="BorderBrush"
                            Value="#3D3D3D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsPressed}"
                             Value="True">
                    <Setter Property="BorderBrush"
                            Value="#52BCCC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}"
                             Value="True">
                    <Setter Property="Foreground"
                            Value="#262626" />
                </DataTrigger>
            </Style.Triggers>
        </Style>


    </views:BaseView.Resources>

    <!-- ========================= -->
    <!-- ROOT BASE: Gradient Background -->
    <!-- ========================= -->
    <Grid Background="{DynamicResource SurfaceBgBrush}"
          TextElement.FontFamily="{StaticResource InterFontFamily}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- ROW 0: TOP BAR -->
        <!-- ========================= -->
        <Grid Grid.Row="0">
            <!-- Logo Top Left -->
            <Grid HorizontalAlignment="Left"
      Margin="14,0,0,0">

                <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center">

                    <!-- Logo Icon -->
                    <svg:SvgViewbox
            Source="pack://application:,,,/Bhive;component/Images/Modern/Logowithname.svg"
            Width="28"
            Height="28"
            VerticalAlignment="Center"/>

                    <!-- Brand Text -->
                    <TextBlock Text="Bhive"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="10,0,0,0"
                   VerticalAlignment="Center"/>
                </StackPanel>

            </Grid>

            <!-- Window Controls Top Right -->
            <StackPanel VerticalAlignment="Top" 
                        HorizontalAlignment="Right" 
                        Orientation="Horizontal"
                        Margin="0,4,10,0">
                
                <!-- Diagonal Arrows (Focus Mode) -->
                <Button Width="35"
                        Height="35"
                        Background="Transparent"
                        BorderThickness="0"
                        Style="{StaticResource ModernHoverButton}"
                        ToolTip="Focus Mode"
                        Command="{Binding ModernWindowViewModel.SetWindowModeCommand, Source={StaticResource Locator}}"
                        CommandParameter="{x:Static enums:WindowMode.Dock}">

                    <svg:SvgViewbox
                        Source="pack://application:,,,/Bhive;component/Images/Modern/Focus_mode.svg"
                        Width="16"
                        Height="16"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>
                </Button>



                <!-- Minimize -->
                <Button Width="35"
                        Height="35"
                        Background="Transparent"
                        BorderThickness="0"
                        Style="{StaticResource ModernHoverButton}">

                    <svg:SvgViewbox
                        Source="pack://application:,,,/Bhive;component/Images/Modern/Minimize.svg"
                        Width="16"
                        Height="16"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ========================= -->
        <!-- ROW 1: MAIN CONTENT -->
        <!-- ========================= -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- COL 1: LEFT RAIL (Transparent on Gradient) -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource BordersBrush}"
                    BorderThickness="0">
                <Border.Resources>
                    <Style x:Key="SidebarRadioButtonStyle" TargetType="RadioButton">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="RadioButton">
                                    <!-- Outer transparent container fills the full 60px rail slot -->
                                    <Grid Background="Transparent">
                                        <!-- Hover highlight Border — snug around content only -->
                                        <Border x:Name="HoverBorder"
                                                CornerRadius="8"
                                                Background="Transparent"
                                                Width="52"
                                                Height="52"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <!-- Content: Icon + Label -->
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">

                                                <!-- Icons Container -->
                                                <Grid Width="20" Height="20" HorizontalAlignment="Center">
                                                    <!-- Active Icon -->
                                                    <svg:SvgViewbox x:Name="ActiveIcon"
                                                                    Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={converters:StringFormatConverter Format='pack://application:,,,/Bhive;component/Images/Modern/{0}_Active.svg'}}"
                                                                    Width="20" Height="20"
                                                                    Visibility="Collapsed"/>
                                                    <!-- Inactive Icon -->
                                                    <svg:SvgViewbox x:Name="InactiveIcon"
                                                                    Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={converters:StringFormatConverter Format='pack://application:,,,/Bhive;component/Images/Modern/{0}_Inactive.svg'}}"
                                                                    Width="20" Height="20"
                                                                    Visibility="Visible"/>
                                                </Grid>

                                                <!-- Label -->
                                                <TextBlock x:Name="LabelText"
                                                           Text="{TemplateBinding Content}"
                                                           FontSize="9"
                                                           FontFamily="{StaticResource InterFontFamily}"
                                                           Foreground="{DynamicResource SecondaryTextActionBrush}"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <ControlTemplate.Triggers>
                                        <!-- Checked State -->
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="ActiveIcon" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="InactiveIcon" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource PrimaryActionBrush}"/>
                                        </Trigger>

                                        <!-- Hover State — highlights only the content border -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="HoverBorder" Property="Background" Value="{DynamicResource OnPageBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Border.Resources>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,14,0,0">
                        
                        <!-- Chat -->
                        <Grid>
                            <RadioButton Style="{StaticResource SidebarRadioButtonStyle}"
                                         Height="60"
                                         GroupName="SidebarGroup"
                                         IsChecked="{Binding DataContext.IsChatVisible, 
                                                    RelativeSource={RelativeSource AncestorType=views:BaseView},
                                                    Mode=OneWay}"
                                         Tag="Chat"
                                         Content="Chat"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="Chat"/>
                            <bhivecontrols:NotificationDot HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,16,0"
                                                           Visibility="{Binding ModernUserChatsViewModel.HasUnreadChatMessages, Source={StaticResource Locator}, Converter={StaticResource BoolToVis}}"/>
                        </Grid>

                        <!-- Notices -->
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}"
                                     Height="60"
                                     GroupName="SidebarGroup"
                                     IsChecked="{Binding DataContext.IsNoticesVisible,
                                                RelativeSource={RelativeSource AncestorType=views:BaseView},
                                                Mode=OneWay}"
                                     Tag="Notice"
                                     Content="Notices"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Notice"/>
                    </StackPanel>

                    <!-- Bottom Settings -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <!-- Manager Hub -->
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}"
                                     Height="60"
                                     GroupName="SidebarGroup"
                                     Tag="ManagerHub"
                                     Content="Manager&#x0a;Hub"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="ManagerHub"/>
                                     
                        <!-- Settings -->
                        <RadioButton Style="{StaticResource SidebarRadioButtonStyle}"
                                     Height="60"
                                     GroupName="SidebarGroup"
                                     Tag="Setting"
                                     Content="Settings"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Setting"/>

                        <!-- Profile Avatar (click opens status overlay) -->
                        <Button Height="60"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                FocusVisualStyle="{x:Null}"
                                ToolTip="Set status"
                                HorizontalAlignment="Stretch"
                                x:Name="AvatarButton"
                                Click="AvatarButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Background="Transparent">
                                        <Border x:Name="AvatarHoverBorder"
                                                Width="45"
                                                Height="45"
                                                CornerRadius="10"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
											<Border.Background>
												<MultiBinding Converter="{StaticResource PresenceWithBreakConverter}">
													<Binding Path="ModernWindowViewModel.CurrentPresence" Source="{StaticResource Locator}" />
													<!--Tea Break.-->
													<Binding Path="DataContext.IsTeaBreakActive" RelativeSource="{RelativeSource AncestorType=Window}"/>
													<Binding Path="DataContext.IsLunchBreakActive" RelativeSource="{RelativeSource AncestorType=Window}"/>
												</MultiBinding>
											</Border.Background>
											<!-- Circular clipped avatar image -->
                                            <Grid Width="36" Height="36"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                                
												<Image Stretch="UniformToFill">
													<Image.Style>
														<Style TargetType="Image">
                                                            <Setter Property="Source" Value="{Binding DataContext.ProfilePicture, Converter={StaticResource NonCachedImageConverter},  RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                            <Style.Triggers>
																<DataTrigger Binding="{Binding DataContext.IsTeaBreakActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
																	<Setter Property="Source" Value="{StaticResource BhiveTeaBreak}"/>
																</DataTrigger>
																<DataTrigger Binding="{Binding DataContext.IsLunchBreakActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
																	<Setter Property="Source" Value="{StaticResource BhiveLunchBreak}"/>
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Image.Style>
												</Image>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="AvatarHoverBorder" Property="Background" Value="{DynamicResource OnPageBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="AvatarHoverBorder" Property="Background" Value="{DynamicResource OnPageBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!--Popup opens when user clicked on avatar-->
                        <Popup x:Name="StatusPopup"
                                PlacementTarget="{Binding ElementName=AvatarButton}"
                                Placement="Bottom"
                                HorizontalOffset="60"
                                VerticalOffset="52"
                                StaysOpen="False"
                                AllowsTransparency="True"
                                PopupAnimation="Fade"
                                IsOpen="False">

                            <Border Width="260" 
                                     Height="260" 
                                     Background="#262626"
                                     CornerRadius="8"
                                     BorderBrush="#6D6D6D"
                                     BorderThickness="1">

                                <Grid Margin="4">

                                    <!--row = 0, header area-->
                                    <Grid Height="30" VerticalAlignment="Top">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Set status"
                                                   Foreground="White"
                                                   FontFamily="{StaticResource InterFontFamily}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Margin="2"
                                                   VerticalAlignment="Center"/>

                                        <!--SVG for close-->
                                        <Button Grid.Column="1"
                                                Width="20" 
                                                Height="20"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                VerticalAlignment="Center"
                                                x:Name="ClosePopup"
                                                Click="ClosePopup_Click">
                                            
                                            <svg:SvgViewbox Source="pack://application:,,,/Bhive;component/Images/Modern/Cancel.svg"
                                                            Width="10" 
                                                            Height="10"
                                                            Stretch="Uniform"/>

                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bd"
                                                                        Background="Transparent"
                                                                        CornerRadius="999"
                                                                        Width="22"
                                                                        Height="22">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center" />
                                                                </Border>

                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver"
                                                                             Value="True">
                                                                        <Setter TargetName="bd"
                                                                                Property="Background"
                                                                                Value="#2A2D3E" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed"
                                                                             Value="True">
                                                                        <Setter TargetName="bd"
                                                                                Property="Background"
                                                                                Value="#3A3F5A" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled"
                                                                             Value="False">
                                                                        <Setter Property="Opacity"
                                                                                Value="0.4" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>

                                    <!--Row = 1, texbox area-->
                                    <Border Height="130"
                                            Margin="0,-55,0,0"
                                            BorderThickness="1"
                                            BorderBrush="#6D6D6D"
                                            Background="#3D3D3D"
                                            Padding="6"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBox x:Name="StatusMessageTextBox"
                                                     Text="{Binding CurrentStatusMessage, UpdateSourceTrigger=PropertyChanged}"
                                                     MaxLength="140"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     Foreground="#D1D1D1"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     FontFamily="{StaticResource InterFontFamily}"
                                                     FontSize="14"
                                                     FontStyle="Normal"
                                                     Height="100"
                                                     VerticalAlignment="Top"
                                                     CaretBrush="White"/>
                                            <TextBlock x:Name="CharacterCountText"
                                                       Text="{Binding ElementName=StatusMessageTextBox, Path=Text.Length, Converter={StaticResource CharacterCountConverter}}"
                                                       Foreground="#D1D1D1"
                                                       FontFamily="{StaticResource InterFontFamily}"
                                                       FontSize="12"
                                                       FontStyle="Italic"
                                                       VerticalAlignment="Bottom"
                                                       HorizontalAlignment="Right"
                                                       />
                                        </StackPanel>
                                    </Border>

                                    <!--Row=2, save button-->
                                    <Button x:Name="SaveStatusButton"
                                            Content="Save"
                                            Style="{StaticResource BhiveSaveButtonStyle}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,170,0,0"
                                            IsEnabled="{Binding IsSaveEnabled}"
                                            Command="{Binding SaveStatusCommand}"/>

                                    <!--Row=3, horizontal line-->
                                    <Border Height="1"
                                            Width="360"
                                            HorizontalAlignment="Stretch"
                                            Background="#6D6D6D"
                                            VerticalAlignment="Top"
                                            Margin="0,208,0,0"/>

                                    <!--row=4, reset and logout button-->
                                    <Grid Height="35" VerticalAlignment="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" 
                                                x:Name="RestartButton"
                                                Content="Restart"
                                                Style="{StaticResource BhiveButtonStyle}"
                                                HorizontalAlignment="left"
                                                VerticalAlignment="Center"
                                                Command="{Binding RestartCommand}"/>

                                        <Button Grid.Column="1" 
                                                x:Name="LogoutButton"
                                                Content="Logout"
                                                Style="{StaticResource BhiveButtonStyle}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Background="#FF4D4D"
                                                Foreground="white"
                                                Command="{Binding LogoutCommand}"
                                                Click="LogoutButton_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Popup>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- COL 2 & 3: MAIN CONTENT HOST -->
            <Grid Grid.Column="1" Grid.ColumnSpan="2">
                
                <!-- Modern Chat View -->
                <local:ModernChatView Visibility="{Binding DataContext.IsChatVisible, RelativeSource={RelativeSource AncestorType=local:FullScreen}, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                
                <!-- Notices View -->
                <local:NoticesView Visibility="{Binding DataContext.IsNoticesVisible, RelativeSource={RelativeSource AncestorType=local:FullScreen}, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                     
                <!-- Manager Hub View -->
                <!--<local:ManagerHubView Visibility="{Binding DataContext.IsManagerHubVisible, RelativeSource={RelativeSource AncestorType=local:FullScreen}, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>-->

                <!-- Settings View -->
                <local:SettingsView Visibility="{Binding DataContext.IsSettingsVisible, RelativeSource={RelativeSource AncestorType=local:FullScreen}, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>

            </Grid>
        </Grid>
    </Grid>
</views:BaseView>

